# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://court:court@db:5432/court_mgmt

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Environment ────────────────────────────────────────────────────────────────
# "production" enables Secure cookie flag and tighter CORS
ENVIRONMENT=development

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Admin seed account ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Cache ──────────────────────────────────────────────────────────────────────
# Redis URL — defaults to redis://redis:6379/0 (Docker Compose service name)
REDIS_URL=redis://redis:6379/0

# ── Observability ──────────────────────────────────────────────────────────────
# Leave blank to disable Sentry (both backend and frontend use the same DSN)
SENTRY_DSN=
# For Next.js frontend Sentry (set same DSN in frontend env if using @sentry/nextjs)
NEXT_PUBLIC_SENTRY_DSN=

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith (AI agent tracing) ───────────────────────────────────────────────
# Set LANGSMITH_TRACING=true and supply an API key to send LangGraph traces to
# LangSmith. Leave blank in development to avoid billing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=court-mgmt-prod

# ── PostgreSQL (used by db service in Docker Compose) ──────────────────────────
POSTGRES_DB=court_mgmt
POSTGRES_USER=court
POSTGRES_PASSWORD=court
